# Snowflake → Snowflake — copy to .env (never commit .env)

# Source (read) — production or replica account
# Format: snowflake://USER:PASSWORD@ACCOUNT/DB/SCHEMA?warehouse=WH&role=ROLE
SNOWFLAKE_SOURCE_URI=snowflake://SRC_USER:SRC_PASS@xy12345.us-east-1/SRC_DB/SRC_SCHEMA?warehouse=SRC_WH&role=SRC_ROLE

# Destination (write) — analytics / dev / DR account
SNOWFLAKE_DEST_URI=snowflake://DEST_USER:DEST_PASS@ab67890.us-east-1/DEST_DB/DEST_SCHEMA?warehouse=DEST_WH&role=DEST_ROLE
